<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ตั้งค่าขั้นสูง - {{ account.account_name }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #14AFAF 0%, #0D7377 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            background: white;
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .header h1 {
            font-size: 28px;
            font-weight: 700;
            background: linear-gradient(135deg, #14AFAF 0%, #0D7377 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 5px;
        }

        .header .breadcrumb {
            background: none;
            padding: 0;
            margin: 0;
            font-size: 14px;
        }

        .settings-card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .settings-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }

        .settings-card h3 {
            font-size: 22px;
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .settings-card h3 i {
            color: #14AFAF;
        }

        .settings-card .description {
            color: #666;
            font-size: 14px;
            margin-bottom: 25px;
            padding-left: 35px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .form-label .badge {
            font-size: 11px;
            font-weight: 500;
        }

        .form-control, .form-select {
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            padding: 12px 15px;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .form-control:focus, .form-select:focus {
            border-color: #14AFAF;
            box-shadow: 0 0 0 0.2rem rgba(20, 175, 175, 0.15);
        }

        .form-text {
            color: #888;
            font-size: 13px;
            margin-top: 5px;
            display: block;
        }

        .error-code-item {
            background: #f8f9fa;
            border-left: 4px solid #14AFAF;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .error-code-item .code-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .error-code-item .code-number {
            font-size: 18px;
            font-weight: 700;
            color: #14AFAF;
        }

        .error-code-item .code-name {
            font-size: 14px;
            font-weight: 600;
            color: #333;
            margin-bottom: 5px;
        }

        .error-code-item .code-description {
            font-size: 13px;
            color: #666;
            margin-bottom: 10px;
        }

        .error-code-item .reasons {
            background: white;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 10px;
        }

        .error-code-item .reasons .title {
            font-size: 12px;
            font-weight: 600;
            color: #14AFAF;
            margin-bottom: 5px;
        }

        .error-code-item .reasons ul {
            margin: 0;
            padding-left: 20px;
            font-size: 12px;
            color: #666;
        }

        .toggle-switch {
            position: relative;
            display: inline-block;
            width: 60px;
            height: 30px;
        }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 30px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 22px;
            width: 22px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background: linear-gradient(135deg, #14AFAF 0%, #0D7377 100%);
        }

        input:checked + .slider:before {
            transform: translateX(30px);
        }

        .btn-primary {
            background: linear-gradient(135deg, #14AFAF 0%, #0D7377 100%);
            border: none;
            border-radius: 10px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(20, 175, 175, 0.3);
        }

        .btn-secondary {
            background: #6c757d;
            border: none;
            border-radius: 10px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-secondary:hover {
            background: #5a6268;
            transform: translateY(-2px);
        }

        .alert {
            border-radius: 10px;
            border: none;
            padding: 15px 20px;
        }

        .alert-info {
            background: linear-gradient(135deg, #e0f7fa 0%, #b2ebf2 100%);
            color: #00695c;
        }

        .alert-warning {
            background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
            color: #e65100;
        }

        .info-box {
            background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
            border-left: 4px solid #2196f3;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .info-box i {
            color: #2196f3;
            margin-right: 10px;
        }

        .example-box {
            background: #f8f9fa;
            border: 2px dashed #dee2e6;
            border-radius: 8px;
            padding: 15px;
            margin-top: 10px;
        }

        .example-box .title {
            font-weight: 600;
            color: #495057;
            margin-bottom: 10px;
            font-size: 13px;
        }

        .example-box .example-item {
            background: white;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 8px;
            font-size: 13px;
        }

        .example-box .example-item strong {
            color: #14AFAF;
        }

        .back-button {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #14AFAF;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .back-button:hover {
            color: #0D7377;
            transform: translateX(-5px);
        }

        @media (max-width: 768px) {
            .container {
                padding: 10px;
            }

            .settings-card {
                padding: 20px;
            }

            .header h1 {
                font-size: 22px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <a href="/dashboard" class="back-button">
                <i class="fas fa-arrow-left"></i> กลับไปหน้าแดชบอร์ด
            </a>
            <h1><i class="fas fa-cog"></i> ตั้งค่าขั้นสูง</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/dashboard">แดชบอร์ด</a></li>
                    <li class="breadcrumb-item"><a href="/line-accounts">บัญชี LINE OA</a></li>
                    <li class="breadcrumb-item active">{{ account.account_name }}</li>
                </ol>
            </nav>
        </div>

        <!-- Info Alert -->
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i>
            <strong>คำแนะนำ:</strong> หน้านี้ใช้สำหรับตั้งค่าขั้นสูง เช่น การตอบกลับอัตโนมัติ และข้อความ Error Code ต่างๆ
        </div>

        <!-- Response Messages Settings -->
        <div class="settings-card">
            <h3><i class="fas fa-comment-dots"></i> การตั้งค่าข้อความตอบกลับอัตโนมัติ</h3>
            <p class="description">กำหนดข้อความที่ระบบจะตอบกลับในสถานการณ์ต่างๆ</p>

            <form id="responseMessagesForm">
                <input type="hidden" name="account_id" value="{{ account.channel_id }}">

                <!-- System Closed Message -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-power-off"></i> ข้อความเมื่อระบบปิด
                        <span class="badge bg-danger">สำคัญ</span>
                    </label>
                    <div class="info-box">
                        <i class="fas fa-lightbulb"></i>
                        <strong>วิธีใช้งาน:</strong> ใส่ข้อความที่ต้องการตอบกลับเมื่อระบบปิด หรือใส่ "0" เพื่อไม่ตอบกลับ
                    </div>
                    <input type="text" class="form-control" name="system_closed" 
                           placeholder='เช่น "ขออภัย ระบบปิดปรับปรุงชั่วคราว" หรือ "0" เพื่อไม่ตอบกลับ'
                           value="{{ response_messages.get('system_closed', {}).get('message', '') }}">
                    <small class="form-text">
                        💡 ใส่ <code>0</code> หรือเว้นว่าง = ไม่ตอบกลับ | ใส่ข้อความ = ตอบกลับตามข้อความที่ใส่
                    </small>
                    
                    <div class="example-box">
                        <div class="title">ตัวอย่าง:</div>
                        <div class="example-item">
                            <strong>ตัวอย่างที่ 1:</strong> "ขออภัย ระบบปิดปรับปรุงชั่วคราว กรุณาลองใหม่ภายหลัง"
                        </div>
                        <div class="example-item">
                            <strong>ตัวอย่างที่ 2:</strong> "0" (ไม่ตอบกลับ)
                        </div>
                    </div>
                </div>

                <!-- Welcome Message -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-hand-wave"></i> ข้อความต้อนรับ
                    </label>
                    <input type="text" class="form-control" name="welcome" 
                           placeholder='เช่น "สวัสดีครับ ยินดีต้อนรับ" หรือ "0" เพื่อไม่ตอบกลับ'
                           value="{{ response_messages.get('welcome', {}).get('message', '') }}">
                    <small class="form-text">
                        ข้อความที่จะส่งเมื่อผู้ใช้เพิ่มเพื่อนครั้งแรก
                    </small>
                </div>

                <!-- Fallback Message -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-question-circle"></i> ข้อความเมื่อไม่เข้าใจ
                    </label>
                    <input type="text" class="form-control" name="fallback" 
                           placeholder='เช่น "ขออภัย ไม่เข้าใจคำถาม" หรือ "0" เพื่อไม่ตอบกลับ'
                           value="{{ response_messages.get('fallback', {}).get('message', '') }}">
                    <small class="form-text">
                        ข้อความที่จะส่งเมื่อระบบไม่เข้าใจคำถามของผู้ใช้
                    </small>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> บันทึกการตั้งค่าข้อความ
                </button>
            </form>
        </div>

        <!-- Error Codes Settings -->
        <div class="settings-card">
            <h3><i class="fas fa-exclamation-triangle"></i> การตั้งค่า Error Codes</h3>
            <p class="description">กำหนดข้อความที่จะแสดงเมื่อเกิด Error แต่ละประเภท</p>

            <div class="alert alert-warning">
                <i class="fas fa-info-circle"></i>
                <strong>หมายเหตุ:</strong> Error Code จะแสดงในข้อความตอบกลับเพื่อให้ทราบสาเหตุของปัญหา
            </div>

            <form id="errorCodesForm">
                <input type="hidden" name="account_id" value="{{ account.channel_id }}">

                {% for error_code in error_codes %}
                <div class="error-code-item">
                    <div class="code-header">
                        <span class="code-number">[{{ error_code.code }}]</span>
                    </div>
                    <div class="code-name">{{ error_code.name }}</div>
                    <div class="code-description">{{ error_code.description }}</div>
                    
                    <div class="reasons">
                        <div class="title">สาเหตุที่เป็นไปได้:</div>
                        <ul>
                            {% for reason in error_code.reasons %}
                            <li>{{ reason }}</li>
                            {% endfor %}
                        </ul>
                    </div>

                    <div class="form-group mb-0">
                        <label class="form-label">ข้อความที่จะตอบกลับ:</label>
                        <input type="text" class="form-control" 
                               name="error_{{ error_code.code }}" 
                               placeholder="{{ error_code.default_message }}"
                               value="{{ custom_error_messages.get(error_code.code, '') }}">
                        <small class="form-text">
                            ค่าเริ่มต้น: {{ error_code.default_message }}
                        </small>
                    </div>
                </div>
                {% endfor %}

                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> บันทึกการตั้งค่า Error Codes
                </button>
            </form>
        </div>

        <!-- Back Button -->
        <div class="text-center mb-4">
            <a href="/line-accounts" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> กลับไปหน้าบัญชี LINE OA
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Save Response Messages
        document.getElementById('responseMessagesForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData);

            try {
                const response = await fetch('/api/response-messages', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                
                if (result.success) {
                    alert('✅ บันทึกการตั้งค่าข้อความสำเร็จ');
                    location.reload();
                } else {
                    alert('❌ เกิดข้อผิดพลาด: ' + result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('❌ เกิดข้อผิดพลาดในการบันทึก');
            }
        });

        // Save Error Codes
        document.getElementById('errorCodesForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData);

            try {
                const response = await fetch('/api/error-codes', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                
                if (result.success) {
                    alert('✅ บันทึกการตั้งค่า Error Codes สำเร็จ');
                    location.reload();
                } else {
                    alert('❌ เกิดข้อผิดพลาด: ' + result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('❌ เกิดข้อผิดพลาดในการบันทึก');
            }
        });
    </script>
</body>
</html>

